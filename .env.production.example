# Production — values are injected by GitHub Actions secrets; this is documentation only
APPLICATION_MODE=production
NEXT_PUBLIC_VERSION=REST
NEXT_PUBLIC_REST_API_ENDPOINT=https://api.plantathome.in/api
NEXT_PUBLIC_SHOP_URL=https://plantathome.in
NEXT_PUBLIC_AUTH_TOKEN_KEY=AUTH_CRED
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
