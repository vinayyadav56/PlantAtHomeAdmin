# Staging — copy to rest/.env.staging.local and fill in secrets
APPLICATION_MODE=staging
NEXT_PUBLIC_VERSION=REST
NEXT_PUBLIC_REST_API_ENDPOINT=https://plantathome-production.up.railway.app/api
NEXT_PUBLIC_SHOP_URL=https://plantathome-shop-staging.vercel.app
NEXT_PUBLIC_AUTH_TOKEN_KEY=AUTH_CRED
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_AVAILABLE_LANGUAGES=en
NEXT_PUBLIC_ENABLE_MULTI_LANG=false
NEXT_PUBLIC_PUSHER_ENABLED=false
